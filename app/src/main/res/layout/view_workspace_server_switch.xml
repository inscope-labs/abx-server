<?xml version="1.0" encoding="utf-8"?>
<merge xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    tools:parentTag="android.widget.FrameLayout">

    <FrameLayout
        android:id="@+id/switchTrack"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="@drawable/bg_switch_track">

        <View
            android:id="@+id/switchThumb"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:background="@drawable/bg_switch_thumb" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:orientation="horizontal">

            <TextView
                android:id="@+id/txtWorkspaceLabel"
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="1"
                android:gravity="center"
                android:text="@string/label_workspace"
                android:textAppearance="@style/TextAppearance.Abx.LabelMedium"
                android:textColor="@color/color_on_primary" />

            <TextView
                android:id="@+id/txtServerLabel"
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="1"
                android:gravity="center"
                android:text="@string/label_server"
                android:textAppearance="@style/TextAppearance.Abx.LabelMedium"
                android:textColor="@color/color_on_surface_variant" />
        </LinearLayout>

    </FrameLayout>
</merge>
