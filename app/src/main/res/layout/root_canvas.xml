<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/rootCanvas"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/canvas_medium_gray">

    <!--
        Root canvas. Always visible — the gray background must remain visible
        around every element below via the 16dp minimum margin rule (eased
        down from the original 32dp). This margin rule applies to all content
        in this layout EXCEPT the top toolbar below, which spans edge-to-edge
        by design; mainContentContainer's top constraint attaches to the
        toolbar's bottom edge rather than parent's top, keeping 16dp from it.
    -->

    <!--
        Permanent app-wide toolbar. Fixed at ?attr/actionBarSize (the
        standard minimum Toolbar/MaterialToolbar height — 56dp portrait /
        48dp landscape) with no collapsing/scroll behavior attached, so it
        never grows beyond that. Hamburger nav icon on the left (unwired —
        no drawer exists yet), centered title, overflow (three-dot) menu on
        the right via root_toolbar_menu.xml.
    -->
    <com.google.android.material.appbar.MaterialToolbar
        android:id="@+id/rootToolbar"
        android:layout_width="0dp"
        android:layout_height="?attr/actionBarSize"
        android:background="?attr/colorPrimary"
        android:theme="@style/ThemeOverlay.AppCompat.Dark.ActionBar"
        app:popupTheme="@style/ThemeOverlay.AppCompat.Light"
        app:title="@string/app_name"
        app:titleCentered="true"
        app:navigationIcon="@drawable/ic_menu_hamburger"
        app:menu="@menu/root_toolbar_menu"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <!--
        Single fragment host. Exactly one of LoadingFragment / ChatFragment /
        FilesFragment occupies this container at any moment, via
        FragmentTransaction.replace() — never more than one shown at once.
        Chat and Files always render at these exact same coordinates, which
        is what makes the toggle-swap visually verifiable.

        Standard rounded corners: rounded_container_bg supplies the shape,
        and clipToOutline clips whatever fragment is currently hosted
        (including its full-bleed background color) to that shape.
    -->
    <androidx.fragment.app.FragmentContainerView
        android:id="@+id/mainContentContainer"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:background="@drawable/rounded_container_bg"
        android:clipToOutline="true"
        android:outlineProvider="background"
        app:layout_constraintTop_toBottomOf="@id/rootToolbar"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintBottom_toTopOf="@id/chatFilesToggleRow"
        android:layout_marginTop="16dp"
        android:layout_marginStart="16dp"
        android:layout_marginEnd="16dp"
        android:layout_marginBottom="16dp" />

    <!--
        Chat / Files toggle. Hidden (GONE) until the loading gate completes
        and the default Files view is shown — see MainActivity.
    -->
    <LinearLayout
        android:id="@+id/chatFilesToggleRow"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center"
        android:visibility="gone"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintBottom_toBottomOf="parent"
        android:layout_marginStart="16dp"
        android:layout_marginEnd="16dp"
        android:layout_marginBottom="16dp">

        <TextView
            android:id="@+id/toggleLabelFiles"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Files"
            android:textColor="@color/black"
            android:layout_marginEnd="8dp" />

        <androidx.appcompat.widget.SwitchCompat
            android:id="@+id/chatFilesToggle"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content" />

        <TextView
            android:id="@+id/toggleLabelChat"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Chat"
            android:textColor="@color/black"
            android:layout_marginStart="8dp" />

    </LinearLayout>

</androidx.constraintlayout.widget.ConstraintLayout>
