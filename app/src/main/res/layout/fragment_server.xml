<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/color_background"
    android:orientation="vertical">

    <!-- Top Tab Navigation -->
    <com.google.android.material.tabs.TabLayout
        android:id="@+id/filesTabLayout"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@color/color_surface"
        app:tabIndicatorColor="@color/color_primary"
        app:tabIndicatorHeight="2dp"
        app:tabMode="scrollable"
        app:tabSelectedTextColor="@color/color_primary"
        app:tabTextAppearance="@style/TextAppearance.Abx.LabelMedium"
        app:tabTextColor="@color/color_on_surface_variant" />

    <View style="@style/Widget.Abx.ListRow.Divider" />

    <!-- Scrollable content container for tabs -->
    <androidx.core.widget.NestedScrollView
        android:id="@+id/filesScrollView"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:fillViewport="true">

        <FrameLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:padding="@dimen/spacing_lg">

            <!-- TAB 1: CONNECT -->
            <LinearLayout
                android:id="@+id/containerConnectTab"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:visibility="visible">

                <!-- Pairing Status Banner -->
                <com.google.android.material.card.MaterialCardView
                    style="@style/Widget.Abx.Card"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="@dimen/spacing_md">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:gravity="center_vertical"
                        android:orientation="horizontal">

                        <ImageView
                            android:id="@+id/imgGatewayStatusIcon"
                            android:layout_width="@dimen/icon_size_md"
                            android:layout_height="@dimen/icon_size_md"
                            android:layout_marginEnd="@dimen/spacing_md"
                            android:src="@drawable/ic_link_off"
                            app:tint="@color/color_on_surface_variant" />

                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:orientation="vertical">

                            <TextView
                                style="@style/TextAppearance.Abx.TitleSmall"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Gateway Pairing Status" />

                            <TextView
                                android:id="@+id/txtGatewayStatus"
                                style="@style/TextAppearance.Abx.BodySmall"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Not Paired (Local Mode Only)" />
                        </LinearLayout>
                    </LinearLayout>
                </com.google.android.material.card.MaterialCardView>

                <!-- Enrollment Status Message -->
                <TextView
                    android:id="@+id/txtEnrollStatus"
                    style="@style/TextAppearance.Abx.BodyMedium"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="@dimen/spacing_md"
                    android:background="@color/color_primary_container"
                    android:padding="@dimen/spacing_md"
                    android:textColor="@color/color_on_primary_container"
                    android:visibility="gone" />

                <!-- Device Identity Card -->
                <com.google.android.material.card.MaterialCardView
                    style="@style/Widget.Abx.Card"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="@dimen/spacing_lg">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical">

                        <TextView
                            style="@style/TextAppearance.Abx.TitleMedium"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="@string/section_device_identity" />

                        <View
                            style="@style/Widget.Abx.ListRow.Divider"
                            android:layout_marginTop="@dimen/spacing_sm"
                            android:layout_marginBottom="@dimen/spacing_md" />

                        <TextView
                            style="@style/TextAppearance.Abx.LabelMedium"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="@string/label_fingerprint_title" />

                        <TextView
                            android:id="@+id/txtConnectFingerprint"
                            style="@style/TextAppearance.Abx.Monospace"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="@dimen/spacing_xs"
                            android:background="@color/color_surface_variant"
                            android:padding="@dimen/spacing_sm"
                            android:text="•••• •••• •••• ••••" />

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="@dimen/spacing_md"
                            android:orientation="horizontal">

                            <com.google.android.material.button.MaterialButton
                                android:id="@+id/btnConnectCopyFingerprint"
                                style="@style/Widget.Material3.Button.OutlinedButton"
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:layout_weight="1"
                                android:layout_marginEnd="@dimen/spacing_sm"
                                android:text="@string/btn_copy_fingerprint"
                                app:cornerRadius="@dimen/radius_md" />

                            <com.google.android.material.button.MaterialButton
                                android:id="@+id/btnConnectToggleFingerprint"
                                style="@style/Widget.Material3.Button.TextButton"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="@string/btn_view_full" />
                        </LinearLayout>
                    </LinearLayout>
                </com.google.android.material.card.MaterialCardView>

                <!-- Verification QR Code Card -->
                <com.google.android.material.card.MaterialCardView
                    style="@style/Widget.Abx.Card"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="@dimen/spacing_lg">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:gravity="center_horizontal"
                        android:orientation="vertical">

                        <TextView
                            style="@style/TextAppearance.Abx.TitleMedium"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:text="@string/section_verification" />

                        <View
                            style="@style/Widget.Abx.ListRow.Divider"
                            android:layout_marginTop="@dimen/spacing_sm"
                            android:layout_marginBottom="@dimen/spacing_md" />

                        <ImageView
                            android:id="@+id/imgConnectQrCode"
                            android:layout_width="180dp"
                            android:layout_height="180dp"
                            android:background="@color/color_white"
                            android:padding="@dimen/spacing_sm" />

                        <TextView
                            style="@style/TextAppearance.Abx.BodySmall"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="@dimen/spacing_md"
                            android:text="@string/desc_verification_instruction"
                            android:textAlignment="center" />

                        <com.google.android.material.button.MaterialButton
                            android:id="@+id/btnSimulateEnrollment"
                            style="@style/Widget.Material3.Button.TonalButton"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="@dimen/spacing_lg"
                            android:text="@string/mock_pairing_button"
                            app:cornerRadius="@dimen/radius_md"
                            app:icon="@drawable/ic_link" />
                    </LinearLayout>
                </com.google.android.material.card.MaterialCardView>

                <!-- Hardware Security Enclave Status Card -->
                <com.google.android.material.card.MaterialCardView
                    style="@style/Widget.Abx.Card"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="@dimen/spacing_lg">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical">

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:gravity="center_vertical"
                            android:orientation="horizontal">

                            <TextView
                                style="@style/TextAppearance.Abx.TitleMedium"
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:layout_weight="1"
                                android:text="@string/label_hardware_enclave" />

                            <TextView
                                android:id="@+id/txtConnectEnclaveChip"
                                style="@style/Widget.Abx.StatusChip"
                                android:text="TEE SECURE" />
                        </LinearLayout>

                        <View
                            style="@style/Widget.Abx.ListRow.Divider"
                            android:layout_marginTop="@dimen/spacing_sm"
                            android:layout_marginBottom="@dimen/spacing_md" />

                        <TextView
                            android:id="@+id/txtProviderBackend"
                            style="@style/TextAppearance.Abx.BodySmall"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Backend: Android KeyStore" />

                        <TextView
                            android:id="@+id/txtKeyIsolation"
                            style="@style/TextAppearance.Abx.BodySmall"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="@dimen/spacing_xs"
                            android:text="Isolation: Hardware Secured" />

                        <TextView
                            android:id="@+id/txtHardwareBacked"
                            style="@style/TextAppearance.Abx.BodySmall"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="@dimen/spacing_xs"
                            android:text="Hardware Backed: YES" />

                        <TextView
                            android:id="@+id/txtStrongBoxSupport"
                            style="@style/TextAppearance.Abx.BodySmall"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="@dimen/spacing_xs"
                            android:text="StrongBox Support: YES" />
                    </LinearLayout>
                </com.google.android.material.card.MaterialCardView>

                <!-- Hardware Enclave Actions Card -->
                <com.google.android.material.card.MaterialCardView
                    style="@style/Widget.Abx.Card"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical">

                        <TextView
                            style="@style/TextAppearance.Abx.TitleMedium"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="@string/section_enclave_actions" />

                        <com.google.android.material.button.MaterialButton
                            android:id="@+id/btnRotateKey"
                            style="@style/Widget.Material3.Button.TonalButton"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="@dimen/spacing_md"
                            android:text="@string/btn_rotate_key"
                            app:cornerRadius="@dimen/radius_md"
                            app:icon="@drawable/ic_refresh" />

                        <com.google.android.material.button.MaterialButton
                            android:id="@+id/btnClearCredentials"
                            style="@style/Widget.Material3.Button.OutlinedButton"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="@dimen/spacing_sm"
                            android:text="@string/btn_clear_credentials"
                            android:textColor="@color/color_error"
                            app:cornerRadius="@dimen/radius_md"
                            app:icon="@drawable/ic_delete"
                            app:iconTint="@color/color_error"
                            app:strokeColor="@color/color_error" />
                    </LinearLayout>
                </com.google.android.material.card.MaterialCardView>
            </LinearLayout>

            <!-- TAB 3: ACCESS -->
            <LinearLayout
                android:id="@+id/containerAccessTab"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:visibility="gone">

                <!-- Session Control Card -->
                <com.google.android.material.card.MaterialCardView
                    style="@style/Widget.Abx.Card"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="@dimen/spacing_lg">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:gravity="center_horizontal"
                        android:orientation="vertical">

                        <TextView
                            android:id="@+id/txtAccessSessionBadge"
                            style="@style/TextAppearance.Abx.LabelLarge"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="INACTIVE / EXPIRED" />

                        <TextView
                            android:id="@+id/txtAccessTtl"
                            style="@style/TextAppearance.Abx.TitleLarge"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="@dimen/spacing_md"
                            android:text="@string/ttl_inactive" />

                        <com.google.android.material.button.MaterialButton
                            android:id="@+id/btnAccessStartStopSession"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="@dimen/spacing_lg"
                            android:paddingVertical="@dimen/spacing_md"
                            android:text="@string/btn_start_session"
                            app:cornerRadius="@dimen/radius_md" />

                        <com.google.android.material.button.MaterialButton
                            android:id="@+id/btnAccessLocalBridge"
                            style="@style/Widget.Material3.Button.OutlinedButton"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="@dimen/spacing_sm"
                            android:text="@string/btn_local_bridge"
                            app:cornerRadius="@dimen/radius_md" />
                    </LinearLayout>
                </com.google.android.material.card.MaterialCardView>

                <!-- Access Policy Summary Card -->
                <com.google.android.material.card.MaterialCardView
                    style="@style/Widget.Abx.Card"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="@dimen/spacing_lg">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical">

                        <TextView
                            style="@style/TextAppearance.Abx.TitleMedium"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="@string/policy_summary_title" />

                        <View
                            style="@style/Widget.Abx.ListRow.Divider"
                            android:layout_marginTop="@dimen/spacing_sm"
                            android:layout_marginBottom="@dimen/spacing_md" />

                        <TextView
                            android:id="@+id/txtAccessPolicyDesc"
                            style="@style/TextAppearance.Abx.BodyMedium"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:text="@string/policy_inactive_desc" />

                        <TextView
                            android:id="@+id/txtAccessPolicyDetails"
                            style="@style/TextAppearance.Abx.BodySmall"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="@dimen/spacing_sm"
                            android:background="@color/color_surface_variant"
                            android:padding="@dimen/spacing_md"
                            android:text="@string/policy_summary_details"
                            android:visibility="gone" />
                    </LinearLayout>
                </com.google.android.material.card.MaterialCardView>

                <!-- Advanced Technical Details Card -->
                <com.google.android.material.card.MaterialCardView
                    style="@style/Widget.Abx.Card"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical">

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:gravity="center_vertical"
                            android:orientation="horizontal">

                            <TextView
                                style="@style/TextAppearance.Abx.TitleSmall"
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:layout_weight="1"
                                android:text="@string/advanced_toggle" />

                            <com.google.android.material.switchmaterial.SwitchMaterial
                                android:id="@+id/switchAccessAdvanced"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content" />
                        </LinearLayout>

                        <TextView
                            android:id="@+id/txtAccessCapabilityJson"
                            style="@style/TextAppearance.Abx.Monospace"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="@dimen/spacing_md"
                            android:background="@color/gray_85"
                            android:padding="@dimen/spacing_md"
                            android:textColor="@color/success_green_40"
                            android:visibility="gone" />
                    </LinearLayout>
                </com.google.android.material.card.MaterialCardView>
            </LinearLayout>

            <!-- TAB 4: REMOVE -->
            <LinearLayout
                android:id="@+id/containerRemoveTab"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:visibility="gone">

                <!-- Uninstall Instructions Card -->
                <com.google.android.material.card.MaterialCardView
                    style="@style/Widget.Abx.Card"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="@dimen/spacing_lg">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical">

                        <TextView
                            style="@style/TextAppearance.Abx.TitleMedium"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="@string/uninstall_instructions_title" />

                        <View
                            style="@style/Widget.Abx.ListRow.Divider"
                            android:layout_marginTop="@dimen/spacing_sm"
                            android:layout_marginBottom="@dimen/spacing_md" />

                        <TextView
                            style="@style/TextAppearance.Abx.BodyMedium"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:text="@string/uninstall_instructions_desc" />
                    </LinearLayout>
                </com.google.android.material.card.MaterialCardView>

                <!-- Data Erasure Card -->
                <com.google.android.material.card.MaterialCardView
                    style="@style/Widget.Abx.Card"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical">

                        <TextView
                            style="@style/TextAppearance.Abx.TitleMedium"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Wipe Cryptographic Data"
                            android:textColor="@color/color_error" />

                        <View
                            style="@style/Widget.Abx.ListRow.Divider"
                            android:layout_marginTop="@dimen/spacing_sm"
                            android:layout_marginBottom="@dimen/spacing_md" />

                        <TextView
                            style="@style/TextAppearance.Abx.BodyMedium"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:text="@string/clear_explanation" />

                        <com.google.android.material.button.MaterialButton
                            android:id="@+id/btnWipeDataCompliance"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="@dimen/spacing_lg"
                            android:backgroundTint="@color/color_error"
                            android:paddingVertical="@dimen/spacing_md"
                            android:text="@string/btn_clear_data"
                            android:textColor="@color/color_on_error"
                            app:cornerRadius="@dimen/radius_md"
                            app:icon="@drawable/ic_delete"
                            app:iconTint="@color/color_on_error" />
                    </LinearLayout>
                </com.google.android.material.card.MaterialCardView>
            </LinearLayout>

            <!-- TAB 5: ACTIVITY -->
            <LinearLayout
                android:id="@+id/containerActivityTab"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:visibility="gone">

                <!-- Audit Logs Header & Integrity Card -->
                <com.google.android.material.card.MaterialCardView
                    style="@style/Widget.Abx.Card"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="@dimen/spacing_md">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical">

                        <TextView
                            style="@style/TextAppearance.Abx.TitleMedium"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="@string/audit_title" />

                        <TextView
                            style="@style/TextAppearance.Abx.BodySmall"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="@dimen/spacing_xs"
                            android:text="@string/audit_subtitle" />

                        <TextView
                            android:id="@+id/txtActivityIntegrity"
                            style="@style/Widget.Abx.StatusChip"
                            android:layout_marginTop="@dimen/spacing_md"
                            android:text="@string/audit_integrity_valid" />
                    </LinearLayout>
                </com.google.android.material.card.MaterialCardView>

                <!-- Interactive Validation Card -->
                <com.google.android.material.card.MaterialCardView
                    style="@style/Widget.Abx.Card"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="@dimen/spacing_md">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical">

                        <TextView
                            style="@style/TextAppearance.Abx.TitleSmall"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Verify System Security" />

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="@dimen/spacing_sm"
                            android:orientation="horizontal">

                            <com.google.android.material.button.MaterialButton
                                android:id="@+id/btnSimulateExpired"
                                style="@style/Widget.Material3.Button.TonalButton"
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:layout_weight="1"
                                android:layout_marginEnd="@dimen/spacing_xs"
                                android:text="Simulate Expired"
                                app:cornerRadius="@dimen/radius_sm" />

                            <com.google.android.material.button.MaterialButton
                                android:id="@+id/btnSimulateOutOfBounds"
                                style="@style/Widget.Material3.Button.TonalButton"
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:layout_weight="1"
                                android:layout_marginStart="@dimen/spacing_xs"
                                android:text="Simulate Out-of-Bounds"
                                app:cornerRadius="@dimen/radius_sm" />
                        </LinearLayout>
                    </LinearLayout>
                </com.google.android.material.card.MaterialCardView>

                <!-- Technical JSON Toggle -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:gravity="center_vertical"
                    android:orientation="horizontal"
                    android:paddingVertical="@dimen/spacing_xs">

                    <TextView
                        style="@style/TextAppearance.Abx.BodyMedium"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="Show Technical JSON Details" />

                    <com.google.android.material.switchmaterial.SwitchMaterial
                        android:id="@+id/switchActivityAdvanced"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content" />
                </LinearLayout>

                <View
                    style="@style/Widget.Abx.ListRow.Divider"
                    android:layout_marginTop="@dimen/spacing_xs"
                    android:layout_marginBottom="@dimen/spacing_md" />

                <!-- Empty state message -->
                <TextView
                    android:id="@+id/txtActivityEmpty"
                    style="@style/TextAppearance.Abx.BodyMedium"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:padding="@dimen/spacing_xl"
                    android:text="@string/audit_empty"
                    android:textAlignment="center"
                    android:textColor="@color/color_on_surface_variant" />

                <!-- Dynamic Log Entries List -->
                <LinearLayout
                    android:id="@+id/layoutActivityLogsList"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical" />
            </LinearLayout>

        </FrameLayout>
    </androidx.core.widget.NestedScrollView>

    <com.inscopelabs.abx.server.workspace.widget.WorkspaceServerSwitch
        android:id="@+id/workspaceServerSwitch"
        android:layout_width="match_parent"
        android:layout_height="44dp"
        android:layout_marginStart="@dimen/spacing_lg"
        android:layout_marginEnd="@dimen/spacing_lg"
        android:layout_marginBottom="@dimen/spacing_lg" />

</LinearLayout>
