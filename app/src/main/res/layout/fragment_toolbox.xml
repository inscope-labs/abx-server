<?xml version="1.0" encoding="utf-8"?>
<!--
    DESIGN TOKEN DISCIPLINE — see design-tokens.md before editing.
-->
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/color_background">

    <!-- Compact Custom Top Bar -->
    <androidx.appcompat.widget.Toolbar
        android:id="@+id/toolboxToolbar"
        style="@style/Widget.Abx.TopBar"
        app:navigationIcon="@drawable/ic_arrow_back"
        app:title="@string/tab_toolbox"
        app:titleTextAppearance="@style/TextAppearance.Abx.TitleMedium"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <!-- Top Tab Navigation (Tools / UserDB) -->
    <com.google.android.material.tabs.TabLayout
        android:id="@+id/toolboxTabLayout"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@color/color_surface"
        app:tabIndicatorColor="@color/color_primary"
        app:tabIndicatorHeight="2dp"
        app:tabMode="fixed"
        app:tabSelectedTextColor="@color/color_primary"
        app:tabTextAppearance="@style/TextAppearance.Abx.LabelMedium"
        app:tabTextColor="@color/color_on_surface_variant"
        app:layout_constraintTop_toBottomOf="@id/toolboxToolbar"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <View
        android:id="@+id/toolboxHeaderDivider"
        style="@style/Widget.Abx.ListRow.Divider"
        app:layout_constraintTop_toBottomOf="@id/toolboxTabLayout"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <!-- TAB 1: TOOLS Container -->
    <ScrollView
        android:id="@+id/containerToolsTab"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:fillViewport="true"
        android:visibility="visible"
        app:layout_constraintTop_toBottomOf="@id/toolboxHeaderDivider"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingHorizontal="@dimen/spacing_lg"
            android:paddingTop="@dimen/spacing_lg">

            <!-- Section Label -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginBottom="@dimen/spacing_sm"
                android:text="@string/menu_utilities"
                android:textAppearance="@style/TextAppearance.Abx.LabelMedium"
                android:textColor="@color/color_primary" />

            <!-- Flat list row for Context Package - NOT a card per row -->
            <LinearLayout
                android:id="@+id/openContextPackageRow"
                style="@style/Widget.Abx.ListRow"
                android:orientation="horizontal"
                android:focusable="true"
                android:clickable="true">

                <FrameLayout style="@style/Widget.Abx.ListRow.IconContainer">
                    <ImageView
                        style="@style/Widget.Abx.ListRow.Icon"
                        android:src="@drawable/ic_inventory"
                        android:contentDescription="@string/context_package_title" />
                </FrameLayout>

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:layout_marginStart="@dimen/spacing_md"
                    android:orientation="vertical">

                    <TextView
                        style="@style/Widget.Abx.ListRow.Title"
                        android:text="@string/context_package_title" />

                    <TextView
                        style="@style/Widget.Abx.ListRow.Subtitle"
                        android:text="@string/context_package_desc" />
                </LinearLayout>

                <ImageView style="@style/Widget.Abx.ListRow.Chevron" />
            </LinearLayout>

            <View style="@style/Widget.Abx.ListRow.Divider" />

        </LinearLayout>
    </ScrollView>

    <!-- TAB 2: USERDB Container (Placeholder) -->
    <FrameLayout
        android:id="@+id/containerUserDbTab"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:visibility="gone"
        app:layout_constraintTop_toBottomOf="@id/toolboxHeaderDivider"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <TextView
            android:id="@+id/txtUserDbPlaceholder"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center"
            android:padding="@dimen/spacing_xl"
            android:text="@string/userdb_placeholder"
            android:textAppearance="@style/TextAppearance.Abx.BodyMedium"
            android:textColor="@color/color_on_surface_variant" />
    </FrameLayout>

</androidx.constraintlayout.widget.ConstraintLayout>
