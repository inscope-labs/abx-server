<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/color_background"
    android:orientation="vertical">

    <androidx.core.widget.NestedScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:fillViewport="true">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="@dimen/spacing_lg">

            <!-- 1. System Health Panel -->
            <com.google.android.material.card.MaterialCardView
                style="@style/Widget.Abx.Card"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="@dimen/spacing_lg">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="@dimen/spacing_lg">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="System Health &amp; Safety Posture"
                        android:textAppearance="@style/TextAppearance.Abx.TitleMedium"
                        android:textColor="@color/color_on_surface" />

                    <View
                        style="@style/Widget.Abx.ListRow.Divider"
                        android:layout_marginTop="@dimen/spacing_sm"
                        android:layout_marginBottom="@dimen/spacing_md" />

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal">

                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:background="@color/color_surface_variant"
                            android:orientation="vertical"
                            android:padding="@dimen/spacing_sm"
                            android:layout_marginEnd="@dimen/spacing_xs">

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Enclave Security"
                                android:textAppearance="@style/TextAppearance.Abx.LabelSmall"
                                android:textColor="@color/color_on_surface_variant" />

                            <TextView
                                android:id="@+id/txtDashEnclaveSecurity"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="TEE Secured"
                                android:textAppearance="@style/TextAppearance.Abx.BodyMedium"
                                android:textColor="@color/color_success" />
                        </LinearLayout>

                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:background="@color/color_surface_variant"
                            android:orientation="vertical"
                            android:padding="@dimen/spacing_sm"
                            android:layout_marginStart="@dimen/spacing_xs">

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Audit Integrity"
                                android:textAppearance="@style/TextAppearance.Abx.LabelSmall"
                                android:textColor="@color/color_on_surface_variant" />

                            <TextView
                                android:id="@+id/txtDashAuditIntegrity"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="SECURE"
                                android:textAppearance="@style/TextAppearance.Abx.BodyMedium"
                                android:textColor="@color/color_success" />
                        </LinearLayout>
                    </LinearLayout>

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="@dimen/spacing_md"
                        android:orientation="horizontal">

                        <TextView
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:text="Gateway Pairing"
                            android:textAppearance="@style/TextAppearance.Abx.BodyMedium"
                            android:textColor="@color/color_on_surface_variant" />

                        <TextView
                            android:id="@+id/txtDashGatewayStatus"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Not Paired (Local Mode Only)"
                            android:textAppearance="@style/TextAppearance.Abx.BodyMedium"
                            android:textColor="@color/color_on_surface_variant" />
                    </LinearLayout>
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- 2. Session Metric & Fingerprint Cards Row -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_marginBottom="@dimen/spacing_lg">

                <com.google.android.material.card.MaterialCardView
                    style="@style/Widget.Abx.Card"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:layout_marginEnd="@dimen/spacing_xs">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:padding="@dimen/spacing_md">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Session Remaining"
                            android:textAppearance="@style/TextAppearance.Abx.LabelSmall"
                            android:textColor="@color/color_on_surface_variant" />

                        <TextView
                            android:id="@+id/txtDashTtl"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Inactive"
                            android:textAppearance="@style/TextAppearance.Abx.TitleMedium"
                            android:textColor="@color/color_on_surface"
                            android:layout_marginTop="@dimen/spacing_xs" />

                        <TextView
                            android:id="@+id/txtDashSessionSub"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Start session in Access tab"
                            android:textAppearance="@style/TextAppearance.Abx.LabelSmall"
                            android:textColor="@color/color_on_surface_variant"
                            android:layout_marginTop="@dimen/spacing_xs" />
                    </LinearLayout>
                </com.google.android.material.card.MaterialCardView>

                <com.google.android.material.card.MaterialCardView
                    style="@style/Widget.Abx.Card"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:layout_marginStart="@dimen/spacing_xs">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:padding="@dimen/spacing_md">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Identity Verified"
                            android:textAppearance="@style/TextAppearance.Abx.LabelSmall"
                            android:textColor="@color/color_on_surface_variant" />

                        <TextView
                            android:id="@+id/txtDashIdentityStatus"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="READY"
                            android:textAppearance="@style/TextAppearance.Abx.TitleMedium"
                            android:textColor="@color/color_success"
                            android:layout_marginTop="@dimen/spacing_xs" />

                        <TextView
                            android:id="@+id/txtDashFingerprintSnippet"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Keys active"
                            android:textAppearance="@style/TextAppearance.Abx.Monospace"
                            android:textColor="@color/color_on_surface_variant"
                            android:layout_marginTop="@dimen/spacing_xs" />
                    </LinearLayout>
                </com.google.android.material.card.MaterialCardView>
            </LinearLayout>

            <!-- 3. Quick Actions Section -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Quick Actions &amp; Workflows"
                android:textAppearance="@style/TextAppearance.Abx.TitleMedium"
                android:textColor="@color/color_on_surface"
                android:layout_marginBottom="@dimen/spacing_sm" />

            <com.google.android.material.card.MaterialCardView
                style="@style/Widget.Abx.Card"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="@dimen/spacing_lg">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="@dimen/spacing_md">

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btnDashToggleSession"
                        style="@style/Widget.Material3.Button"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="Start Session" />

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:layout_marginTop="@dimen/spacing_sm">

                        <com.google.android.material.button.MaterialButton
                            android:id="@+id/btnNavAccess"
                            style="@style/Widget.Material3.Button.TonalButton"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:text="Access Settings"
                            android:layout_marginEnd="@dimen/spacing_xs" />

                        <com.google.android.material.button.MaterialButton
                            android:id="@+id/btnNavRemove"
                            style="@style/Widget.Material3.Button.TonalButton"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:text="Remove / Wipe"
                            android:layout_marginStart="@dimen/spacing_xs" />
                    </LinearLayout>

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btnNavActivity"
                        style="@style/Widget.Material3.Button.OutlinedButton"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="@dimen/spacing_sm"
                        android:text="View Activity Logs" />
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- 4. AI Workspace Summary Card -->
            <com.google.android.material.card.MaterialCardView
                style="@style/Widget.Abx.Card"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="@dimen/spacing_lg">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="@dimen/spacing_lg">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="AI Secure MCP Workspace"
                        android:textAppearance="@style/TextAppearance.Abx.TitleMedium"
                        android:textColor="@color/color_on_surface" />

                    <View
                        style="@style/Widget.Abx.ListRow.Divider"
                        android:layout_marginTop="@dimen/spacing_sm"
                        android:layout_marginBottom="@dimen/spacing_md" />

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:layout_marginBottom="@dimen/spacing_xs">

                        <TextView
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:text="Primary Model Node"
                            android:textAppearance="@style/TextAppearance.Abx.BodyMedium"
                            android:textColor="@color/color_on_surface_variant" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Gemini Server Attested"
                            android:textAppearance="@style/TextAppearance.Abx.BodyMedium"
                            android:textColor="@color/color_on_surface" />
                    </LinearLayout>

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:layout_marginBottom="@dimen/spacing_xs">

                        <TextView
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:text="Security Isolation"
                            android:textAppearance="@style/TextAppearance.Abx.BodyMedium"
                            android:textColor="@color/color_on_surface_variant" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="HSM Isolated Keystore"
                            android:textAppearance="@style/TextAppearance.Abx.BodyMedium"
                            android:textColor="@color/color_success" />
                    </LinearLayout>

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal">

                        <TextView
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:text="Active MCP Policy"
                            android:textAppearance="@style/TextAppearance.Abx.BodyMedium"
                            android:textColor="@color/color_on_surface_variant" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Scoped Sandbox v1.1"
                            android:textAppearance="@style/TextAppearance.Abx.BodyMedium"
                            android:textColor="@color/color_on_surface" />
                    </LinearLayout>
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

        </LinearLayout>
    </androidx.core.widget.NestedScrollView>

</LinearLayout>
